{
  "file": "topic_fork_v4.0.json",
  "version": "4.0-fork",
  "timestamp": "2026-04-07",
  "content": {
    "desc": "Механизм выноса темы в отдельный поток с возвратом результата",

    "enabled": true,
    "requires": ["memory_management_v4.0.json", "validation_schemas_v4.0.json"],

    "commands": {
      "[ВЫНЕСТИ_ТЕМУ: описание]": {
        "desc": "Создать форк текущего контекста для отдельной проработки",
        "syntax": "[ВЫНЕСТИ_ТЕМУ: {краткое_описание}] {детальная_постановка_задачи}",
        "example": "[ВЫНЕСТИ_ТЕМУ: оптимизация SQL-запросов] Проанализируй 3 самых медленных запроса из отчёта, предложи индексы и перепиши их. Верни готовый код.",
        
        "output": {
          "message_1_prompt": {
            "format": "текстовый промт для дочерней сессии",
            "content": [
              "=== КОНТЕКСТ ОСНОВНОЙ СЕССИИ (сжатый) ===",
              "Роль: {role}",
              "Режим: {current_mode}",
              "Ключевые факты: {key_facts}",
              "Активные файлы: {file_list}",
              "Последние решения: {recent_decisions}",
              "",
              "=== ЗАДАЧА ДЛЯ ВЫНОСА ===",
              "{user_query}",
              "",
              "=== ТРЕБОВАНИЯ К ВОЗВРАТУ ===",
              "1. Верни JSON-дамп (второе сообщение) по схеме ниже",
              "2. Промт-сообщение должно быть самодостаточным",
              "3. Укажи оценку затраченных токенов"
            ]
          },
          "message_2_json_dump": {
            "format": "JSON (структурированный дамп контекста)",
            "schema": "fork_export_schema"
          }
        }
      },

      "[ВЕРНУТЬСЯ: ID_форка]": {
        "desc": "Вернуть результат из дочерней сессии в основную",
        "syntax": "[ВЕРНУТЬСЯ: {fork_id}] с результатами:\n{результат_из_дочерней_сессии}",
        "example": "[ВЕРНУТЬСЯ: fork_20260407_143022] с результатами:\n{\"optimized_queries\": [...], \"new_indexes\": [...]}",
        
        "action": "Ассистент интегрирует результат обратно в основной контекст, обновляя состояние",
        
        "integration_steps": [
          "1. Прочитать JSON-дамп результата",
          "2. Сверить с текущим контекстом (нет ли конфликтов)",
          "3. Интегрировать новые данные/решения/файлы",
          "4. Обновить метрики (токены, операции)",
          "5. Выдать вердикт об успешности возврата"
        ]
      },

      "[СТАТУС_ФОРКОВ]": {
        "desc": "Показать все активные форки текущей сессии",
        "output": {
          "active_forks": ["fork_id_1", "fork_id_2"],
          "total_forks_created": 3,
          "total_forks_merged": 1,
          "context_impact": "оценка влияния на основной контекст"
        }
      },

      "[ЗАКРЫТЬ_ФОРК: ID]": {
        "desc": "Закрыть форк без возврата (освободить референс)",
        "action": "Удалить запись о форке из активных"
      }
    },

    "fork_export_schema": {
      "type": "object",
      "required": ["fork_meta", "context_snapshot", "task", "expected_output_format"],
      "properties": {
        "fork_meta": {
          "type": "object",
          "required": ["fork_id", "parent_session_id", "created_at", "ttl_minutes"],
          "properties": {
            "fork_id": {"type": "string", "pattern": "^fork_\\d{8}_\\d{6}$"},
            "parent_session_id": {"type": "string"},
            "created_at": {"type": "string", "format": "date-time"},
            "ttl_minutes": {"type": "integer", "default": 60, "maximum": 1440}
          }
        },
        "context_snapshot": {
          "type": "object",
          "required": ["mode", "token_usage", "active_files", "key_decisions", "recent_messages_summary"],
          "properties": {
            "mode": {"type": "string", "enum": ["efficiency_mode", "deep_analysis_mode", "full_context_mode"]},
            "token_usage": {"type": "integer", "minimum": 0, "maximum": 1000000},
            "token_free_percent": {"type": "integer", "minimum": 0, "maximum": 100},
            "active_files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "size_kb": {"type": "integer"},
                  "key_content_summary": {"type": "string"}
                }
              }
            },
            "key_decisions": {"type": "array", "items": {"type": "string"}},
            "recent_messages_summary": {"type": "string", "maxLength": 2000},
            "pending_questions": {"type": "array", "items": {"type": "string"}}
          }
        },
        "task": {
          "type": "object",
          "required": ["description", "success_criteria", "return_format"],
          "properties": {
            "description": {"type": "string"},
            "success_criteria": {"type": "array", "items": {"type": "string"}},
            "return_format": {
              "type": "object",
              "properties": {
                "type": {"type": "string", "enum": ["json", "text", "code", "table", "mixed"]},
                "schema": {"type": "object", "optional": true}
              }
            },
            "estimated_tokens": {"type": "integer", "optional": true}
          }
        },
        "expected_output_format": {
          "type": "object",
          "required": ["result", "token_usage_fork", "new_files", "decisions_made", "confidence_score"],
          "properties": {
            "result": {"description": "Основной результат выполнения задачи"},
            "token_usage_fork": {"type": "integer"},
            "new_files": {"type": "array", "items": {"type": "string"}},
            "decisions_made": {"type": "array", "items": {"type": "string"}},
            "confidence_score": {"type": "integer", "minimum": 0, "maximum": 100},
            "questions_for_parent": {"type": "array", "items": {"type": "string"}, "optional": true},
            "warnings": {"type": "array", "items": {"type": "string"}, "optional": true}
          }
        }
      }
    },

    "return_result_schema": {
      "type": "object",
      "required": ["fork_id", "result", "execution_summary"],
      "properties": {
        "fork_id": {"type": "string"},
        "result": {
          "type": "object",
          "description": "Результат выполнения (структура определяется expected_output_format из fork)"
        },
        "execution_summary": {
          "type": "object",
          "required": ["tokens_used", "files_created", "decisions", "confidence"],
          "properties": {
            "tokens_used": {"type": "integer"},
            "files_created": {"type": "array", "items": {"type": "string"}},
            "decisions": {"type": "array", "items": {"type": "string"}},
            "confidence": {"type": "integer", "minimum": 0, "maximum": 100},
            "unresolved_issues": {"type": "array", "items": {"type": "string"}}
          }
        },
        "integration_metadata": {
          "type": "object",
          "properties": {
            "conflicts_detected": {"type": "boolean"},
            "conflict_resolution": {"type": "string"},
            "context_impact_tokens": {"type": "integer"}
          }
        }
      }
    },

    "fork_lifecycle": {
      "stages": [
        {
          "stage": "create",
          "action": "[ВЫНЕСТИ_ТЕМУ: ...]",
          "output": "два сообщения (промт + JSON-дамп)",
          "side_effect": "fork_id регистрируется в метаданных сессии"
        },
        {
          "stage": "transfer",
          "action": "пользователь копирует оба сообщения в новую сессию",
          "note": "JSON-дамп загружается как контекст, промт — как задача"
        },
        {
          "stage": "execute",
          "action": "дочерняя сессия выполняет задачу",
          "output": "JSON-результат по схеме expected_output_format"
        },
        {
          "stage": "return",
          "action": "[ВЕРНУТЬСЯ: fork_id] с результатом",
          "side_effect": "интеграция в основной контекст"
        },
        {
          "stage": "close",
          "action": "[ЗАКРЫТЬ_ФОРК: fork_id]",
          "side_effect": "освобождение референса"
        }
      ]
    },

    "context_inheritance": {
      "what_is_inherited": [
        "роль (role)",
        "текущий режим (mode)",
        "активные файлы (только референсы, не полное содержимое)",
        "ключевые решения (summary)",
        "стиль общения"
      ],
      "what_is_NOT_inherited": [
        "полный диалог (только сжатое резюме)",
        "незавершённые команды",
        "кэш поисковых запросов"
      ],
      "compression_ratio": "цель: 10-20% от исходного контекста"
    },

    "return_merge_strategy": {
      "strategy": "умное слияние с разрешением конфликтов",
      "conflict_resolution": {
        "data_conflict": "приоритет у данных из форка (как более свежим) + уведомление",
        "file_conflict": "переименование старого файла, добавление нового",
        "decision_conflict": "запрос пользователя, если оба решения помечены как 'критические'"
      },
      "auto_integration": {
        "new_files": "автоматически загружаются в контекст",
        "decisions": "добавляются в ключевые решения с пометкой [ИЗ_ФОРКА]",
        "token_impact": "прибавляются к текущему использованию"
      }
    },

    "best_practices": [
      "Выносить темы, которые требуют более 50 сообщений или >200K токенов",
      "Перед выносом выполнить //ЭКСПОРТ_КОНТЕКСТА для страховки",
      "Указывать в задаче чёткие success_criteria",
      "Возвращать результат в течение TTL (60 минут по умолчанию)",
      "При возврате проверять, не изменился ли основной контекст (команда //СИСТЕМА_СТАТУС)"
    ],

    "error_handling": {
      "fork_not_found": "Проверить ID форка через [СТАТУС_ФОРКОВ]",
      "context_too_large_for_fork": "Сжать контекст через [CRAFT: КОНТЕКСТ] перед выносом",
      "return_conflicts": "Выполнить ручное разрешение через [КОНТЕКСТ: УТОЧНИТЬ]",
      "ttl_expired": "Создать новый форк, старый игнорировать"
    },

    "example_flow": {
      "user": "[ВЫНЕСТИ_ТЕМУ: оптимизация базы данных] Проанализируй 3 самых медленных запроса из приложенного explain.log, предложи индексы и напиши оптимизированные версии. Верни результат в JSON с полями: original_query, optimized_query, suggested_indexes, expected_improvement_percent.",
      
      "assistant_output_message_1": {
        "type": "prompt_text",
        "content": "=== КОНТЕКСТ ОСНОВНОЙ СЕССИИ ===\nРоль: Экспертный ассистент\nРежим: deep_analysis_mode\nКлючевые факты: работаем над производительностью PostgreSQL\nАктивные файлы: explain.log (2.3MB, 145 медленных запросов)\n\n=== ЗАДАЧА ===\nПроанализируй 3 самых медленных запроса из explain.log, предложи индексы и напиши оптимизированные версии. Верни результат в JSON.\n\n=== ТРЕБОВАНИЯ ===\nВерни JSON по схеме: {queries: [{original, optimized, indexes, improvement_percent}]}"
      },
      
      "assistant_output_message_2": {
        "type": "json_dump",
        "content": {
          "fork_meta": {
            "fork_id": "fork_20260407_143022",
            "parent_session_id": "main_20260407_140000",
            "created_at": "2026-04-07T14:30:22Z",
            "ttl_minutes": 60
          },
          "context_snapshot": {},
          "task": {},
          "expected_output_format": {}
        }
      },
      
      "user_after_fork_complete": "[ВЕРНУТЬСЯ: fork_20260407_143022] с результатами:\n{\"queries\": [{\"original\": \"SELECT * FROM orders...\", \"optimized\": \"SELECT id, status...\", \"indexes\": [\"CREATE INDEX idx_orders_date ON orders(order_date)\"], \"improvement_percent\": 85}]}",
      
      "assistant_final_response": "Результат интегрирован. Обнаружено 2 конфликта с существующими индексами — разрешены в пользу оптимизаций из форка. Обновлён explain.log (добавлен результат). Текущий контекст: +15K токенов.\n[ВЕРДИКТ: РАБОТАЕМ] Свободно: 55%"
    }
  }
}