{
  "file": "validation_schemas_v4.0.json",
  "version": "4.0-v",
  "timestamp": "2026-02-28",
  "content": {
    "export_schema": {
      "type": "object",
      "required": ["meta", "context_summary", "active_elements", "timestamp"],
      "properties": {
        "meta": {
          "type": "object",
          "required": ["protocol_version", "mode", "token_usage", "context_percent"],
          "properties": {
            "protocol_version": {"type": "string", "pattern": "^3\\.0"},
            "mode": {"type": "string", "enum": ["efficiency_mode", "deep_analysis_mode", "full_context_mode"]},
            "token_usage": {"type": "integer", "minimum": 0, "maximum": 1000000},
            "context_percent": {"type": "integer", "minimum": 0, "maximum": 100}
          }
        },
        "context_summary": {
          "type": "object",
          "required": ["core_topic", "key_points", "decisions"],
          "properties": {
            "core_topic": {"type": "string", "minLength": 1, "maxLength": 500},
            "key_points": {"type": "array", "items": {"type": "string"}, "maxItems": 20},
            "decisions": {"type": "array", "items": {"type": "string"}, "maxItems": 10}
          }
        },
        "active_elements": {
          "type": "object",
          "properties": {
            "files": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string"},
                  "size_kb": {"type": "integer"},
                  "pages": {"type": "integer", "optional": true}
                }
              }
            },
            "search_queries": {"type": "array", "items": {"type": "string"}},
            "pending_tasks": {"type": "array", "items": {"type": "string"}}
          }
        },
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },

    "system_integrity_schema": {
      "type": "object",
      "required": ["core_modules", "capability_modules", "system_summary", "compatibility"],
      "properties": {
        "core_modules": {
          "type": "object",
          "minProperties": 3,
          "patternProperties": {
            "^.*_v3\\.0\\.json$": {
              "type": "object",
              "required": ["loaded", "version"],
              "properties": {
                "loaded": {"type": "boolean"},
                "version": {"type": "string", "pattern": "^3\\.0"}
              }
            }
          }
        },
        "capability_modules": {
          "type": "object",
          "minProperties": 2,
          "patternProperties": {
            "^.*_v3\\.0\\.json$": {
              "type": "object",
              "required": ["loaded", "available"],
              "properties": {
                "loaded": {"type": "boolean"},
                "available": {"type": "boolean"}
              }
            }
          }
        },
        "system_summary": {
          "type": "object",
          "required": ["total_modules", "loaded_modules", "critical_loaded"],
          "properties": {
            "total_modules": {"type": "integer", "minimum": 8},
            "loaded_modules": {"type": "integer"},
            "critical_loaded": {"type": "boolean"}
          }
        },
        "compatibility": {
          "type": "object",
          "required": ["version_match", "backwards_compatible"],
          "properties": {
            "version_match": {"type": "boolean"},
            "backwards_compatible": {"type": "boolean"}
          }
        }
      }
    },

    "craft_command_schema": {
      "type": "object",
      "required": ["type", "params", "context"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["OPTIMA", "DETAILED", "MANAGEMENT", "FILES", "SEARCH", "CONTEXT"]
        },
        "params": {
          "type": "object",
          "properties": {
            "mode": {"type": "string"},
            "files": {"type": "array"},
            "depth": {"type": "string", "enum": ["light", "normal", "deep"]}
          }
        },
        "context": {
          "type": "object",
          "properties": {
            "previous_commands": {"type": "array"},
            "active_files": {"type": "array"},
            "token_budget": {"type": "integer"}
          }
        }
      }
    },

    "file_operation_schema": {
      "type": "object",
      "required": ["operation", "file", "status"],
      "properties": {
        "operation": {
          "type": "string",
          "enum": ["upload", "analyze", "compare", "summarize", "extract", "batch"]
        },
        "file": {
          "type": "object",
          "required": ["name", "size_bytes", "type"],
          "properties": {
            "name": {"type": "string"},
            "size_bytes": {"type": "integer", "maximum": 104857600},
            "type": {"type": "string", "enum": ["pdf", "docx", "xlsx", "txt", "md", "csv", "json", "py", "js", "other"]}
          }
        },
        "status": {
          "type": "string",
          "enum": ["success", "partial", "failed"]
        },
        "result_summary": {"type": "string"},
        "token_impact": {"type": "integer"}
      }
    }
  }
}