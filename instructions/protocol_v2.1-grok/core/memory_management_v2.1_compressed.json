{
  "v": "2.1-m", "stage": 2, "desc": "Управление памятью и контекстом",
  "context_monitoring": {
    "requirement": "Оценка после КАЖДОГО ответа",
    "verdicts": {
      "OPTIMAL": {"cond": "50-70%", "label": "[ВЕРДИКТ: ОПТИМАЛЬНЫЙ]"},
      "WORKING": {"cond": "30-50%", "label": "[ВЕРДИКТ: РАБОТАЕМ]"},
      "WARNING": {"cond": "<30%", "label": "[ВЕРДИКТ: ПРЕДУПРЕЖДЕНИЕ]"},
      "STOP": {"cond": "<15%", "label": "[ВЕРДИКТ: СТОП]"},
      "COMPRESSION": {"cond": "Любой %", "label": "[ВЕРДИКТ: КОМПРЕССИЯ]"}
    }
  },
  "proactive_summarization": {
    "triggers": ["Всегда", "Каждые 3-5 ответов", "Новый подтопик"],
    "format": "--- Резюме ---\n* **Цель:** [Суть задачи]\n* **Решения:** [1-2 ключевых]\n* **Текущий фокус:** [Где остановились]\n* **Открытые вопросы:** [Список]\n---"
  },
  "mandatory_verdict": {
    "priority": "highest",
    "desc": "Вердикт в конце КАЖДОГО ответа",
    "error_handling": {"missing": "[КОРРЕКЦИЯ: ВЕРДИКТ] + стандартный", "error": "[ВЕРДИКТ: ОШИБКА] Оценка невозможна"}
  },
  "session_transfer": {"triggers": ["[ВЕРДИКТ: СТОП]", "//ЭКСПОРТ"], "dump_format": {"meta": {"core_topic": "string"}, "key_data": {"achievements": "array"}}}
}