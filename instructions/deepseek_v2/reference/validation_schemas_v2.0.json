{
  "export_schema": {
    "type": "object",
    "required": ["meta", "key_data", "recent_context"],
    "properties": {
      "meta": {
        "type": "object", 
        "required": ["core_topic", "conversation_style", "user_profile"],
        "properties": {
          "core_topic": {"type": "string", "minLength": 1, "maxLength": 255},
          "conversation_style": {"type": "string", "enum": ["формальный эксперт", "тренер", "ассистент"]}
        }
      }
    }
  },
  "system_integrity_schema": {
    "type": "object",
    "required": ["core_modules", "auxiliary_modules", "system_summary"],
    "properties": {
      "core_modules": {"type": "object", "minProperties": 3},
      "auxiliary_modules": {"type": "object", "minProperties": 4}
    }
  }
}