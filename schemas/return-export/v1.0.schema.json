{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/your-org/your-repo/schemas/return-export/v1.0.schema.json",
  "title": "Return Export Configuration Schema",
  "description": "Schema for validating return export configuration dumps",
  "type": "object",
  "required": ["type", "instruction", "parent_topic", "selected_topic", "results_summary", "key_decisions"],
  "properties": {
    "type": {
      "type": "string",
      "const": "return_export"
    },
    "instruction": {
      "type": "string",
      "description": "Instruction for the receiving AI system"
    },
    "parent_topic": {
      "type": "string",
      "description": "Main topic of the parent chat"
    },
    "selected_topic": {
      "type": "string",
      "description": "Topic that was exported for processing"
    },
    "results_summary": {
      "type": "string",
      "description": "Summary of key results and decisions"
    },
    "key_decisions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of key decisions made"
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Artifacts created during processing"
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recommendations for integration"
    },
    "applied_settings": {
      "type": "object",
      "properties": {
        "auto_summary_enabled": { "type": "boolean" },
        "auto_summary_interval": { "type": "integer" },
        "default_response_format": { "type": "string" },
        "verbosity_level": { "type": "string" }
      }
    }
  }
}