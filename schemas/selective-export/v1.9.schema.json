{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pbolkhovitin/ai-protocol-repo/schemas/selective-export/v1.9.schema.json",
  "title": "Selective Export Schema v1.9.0",
  "description": "Schema for validating selective topic export configuration",
  "type": "object",
  "required": ["type", "parent_topic", "selected_topic", "meta", "key_data", "recent_context"],
  "properties": {
    "type": {
      "type": "string",
      "const": "selective_export",
      "description": "Type of export"
    },
    "parent_topic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Main topic of parent chat"
    },
    "selected_topic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Topic selected for export"
    },
    "meta": {
      "type": "object",
      "required": ["core_topic", "conversation_style"],
      "properties": {
        "core_topic": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "conversation_style": {
          "type": "string",
          "enum": ["формальный эксперт", "тренер", "ассистент"]
        },
        "user_profile": {
          "type": "string",
          "description": "User profile information"
        }
      }
    },
    "key_data": {
      "type": "object",
      "required": ["achievements", "constraints"],
      "properties": {
        "achievements": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Important conclusions on the topic"
        },
        "constraints": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Topic-specific constraints"
        },
        "important_facts": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Key data related to the topic"
        }
      }
    },
    "recent_context": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 6,
      "description": "Recent messages on the topic"
    },
    "immediate_next_step": {
      "type": "string",
      "description": "Next action instruction"
    },
    "parent_settings": {
      "type": "object",
      "properties": {
        "auto_summary_enabled": {"type": "boolean"},
        "auto_summary_interval": {"type": "integer"},
        "default_response_format": {
          "type": "string",
          "enum": ["markdown", "plain", "text"]
        },
        "verbosity_level": {
          "type": "string",
          "enum": ["compact", "normal", "detailed"]
        }
      }
    },
    "obsidian_integration": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "note_name_algorithm": {"type": "string"},
        "additional_fields": {
          "type": "object",
          "properties": {
            "obsidian_links": {
              "type": "object",
              "properties": {
                "parent_note": {"type": "string"},
                "related_notes": {
                  "type": "array",
                  "items": {"type": "string"}
                }
              }
            },
            "note_name": {"type": "string"}
          }
        }
      }
    }
  },
  "additionalProperties": false
}