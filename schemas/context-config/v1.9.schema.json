{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pbolkhovitin/ai-protocol-repo/schemas/context-config/v1.9.schema.json",
  "title": "Context Configuration Schema v1.9.0",
  "description": "Schema for validating context configuration files for AI Assistant Protocol v1.9.0",
  "type": "object",
  "required": ["config_version", "type", "meta", "key_data"],
  "properties": {
    "config_version": {
      "type": "string",
      "pattern": "^1\\.9(\\.\\d+)?$",
      "description": "Version of the configuration format"
    },
    "type": {
      "type": "string",
      "const": "context_config",
      "description": "Type of configuration file"
    },
    "meta": {
      "type": "object",
      "required": ["core_topic", "conversation_style", "user_profile"],
      "properties": {
        "core_topic": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Main topic of the conversation"
        },
        "conversation_style": {
          "type": "string",
          "enum": ["формальный эксперт", "тренер", "ассистент"],
          "description": "Style of conversation"
        },
        "user_profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "description": "User profile information"
        },
        "branch_id": {
          "type": "string",
          "description": "Optional branch identifier"
        }
      }
    },
    "key_data": {
      "type": "object",
      "required": ["achievements", "constraints", "important_facts"],
      "properties": {
        "achievements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of main achievements and conclusions"
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "All mentioned constraints and limitations"
        },
        "important_facts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Key data, names, numbers, references"
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Names of created artifacts"
        }
      }
    },
    "parent_settings": {
      "type": "object",
      "properties": {
        "auto_summary_enabled": {
          "type": "boolean",
          "description": "Auto-summary feature status"
        },
        "auto_summary_interval": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Auto-summary interval in messages"
        },
        "default_response_format": {
          "type": "string",
          "enum": ["markdown", "plain", "text"],
          "description": "Default response format"
        },
        "verbosity_level": {
          "type": "string",
          "enum": ["compact", "normal", "detailed"],
          "description": "Verbosity level"
        }
      }
    },
    "obsidian_integration": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Obsidian integration status"
        },
        "note_name_algorithm": {
          "type": "string",
          "description": "Algorithm for note name generation"
        },
        "additional_fields": {
          "type": "object",
          "properties": {
            "obsidian_links": {
              "type": "object",
              "properties": {
                "parent_note": {
                  "type": "string"
                },
                "related_notes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "note_name": {
              "type": "string"
            }
          }
        }
      }
    },
    "immediate_next_step": {
      "type": "string",
      "description": "Next immediate action based on context"
    }
  },
  "additionalProperties": false
}