{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pbolkhovitin/ai-protocol-repo/schemas/deepseek-instructions/v1.9.schema.json",
  "title": "DeepSeek Instructions Schema v1.9.0",
  "description": "Schema for validating DeepSeek assistant instructions configuration",
  "type": "object",
  "required": ["protocol_version", "role", "primary_goal", "modes"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^1\\.9(\\.\\d+)?$",
      "description": "Version of the protocol"
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Primary role of the assistant"
    },
    "style": {
      "type": "string",
      "description": "Communication style of the assistant"
    },
    "primary_goal": {
      "type": "string",
      "minLength": 1,
      "description": "Main goal of the assistant"
    },
    "emphasis": {
      "type": "string",
      "description": "Primary emphasis of responses"
    },
    "modes": {
      "type": "object",
      "required": ["default_mode", "available_modes"],
      "properties": {
        "default_mode": {
          "type": "string",
          "description": "Default operating mode"
        },
        "available_modes": {
          "type": "object",
          "description": "Available operating modes",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "settings": {
                "type": "object",
                "properties": {
                  "command_hint_format": {
                    "type": "string",
                    "enum": ["contextual", "compact", "dynamic_verdict"]
                  },
                  "auto_summary_enabled": {"type": "boolean"},
                  "verbosity_level": {
                    "type": "string",
                    "enum": ["compact", "normal", "detailed"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "protocol": {
      "type": "object",
      "description": "Protocol configuration",
      "properties": {
        "memory_management": {"type": "object"},
        "principles": {"type": "object"},
        "self_monitoring": {"type": "object"}
      }
    },
    "commands": {
      "type": "object",
      "description": "Available commands structure",
      "properties": {
        "format": {"type": "array"},
        "tasks": {"type": "array"},
        "analysis": {"type": "array"},
        "system": {"type": "array"},
        "control": {"type": "array"}
      }
    },
    "confirmation": {
      "type": "string",
      "description": "Activation confirmation message"
    }
  },
  "additionalProperties": false
}