{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "config_version",
    "protocol_version",
    "role",
    "primary_goal",
    "protocol"
  ],
  "properties": {
    "config_version": {
      "type": "string"
    },
    "protocol_version": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "style": {
      "type": "string"
    },
    "primary_goal": {
      "type": "string"
    },
    "emphasis": {
      "type": "string"
    },
    "protocol": {
      "type": "object"
    },
    "commands": {
      "type": "object"
    },
    "principles": {
      "type": "object"
    },
    "confirmation": {
      "type": "string"
    }
  }
}