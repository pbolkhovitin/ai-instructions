{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/deepseek-instructions-schema.json",
  "title": "DeepSeek Instructions Schema",
  "description": "Схема для валидации файла базовых инструкций ассистента",
  "type": "object",
  "required": [
    "config_version",
    "protocol_version",
    "role",
    "style",
    "primary_goal",
    "emphasis",
    "protocol",
    "commands",
    "principles",
    "confirmation"
  ],
  "properties": {
    "config_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$",
      "description": "Версия схемы конфигурационного файла"
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Версия протокола взаимодействия"
    },
    "role": {
      "type": "string",
      "minLength": 1,
      "description": "Роль ассистента"
    },
    "style": {
      "type": "string",
      "minLength": 1,
      "description": "Стиль общения"
    },
    "primary_goal": {
      "type": "string",
      "minLength": 1,
      "description": "Основная цель"
    },
    "emphasis": {
      "type": "string",
      "minLength": 1,
      "description": "Акценты в работе"
    },
    "protocol": {
      "type": "object",
      "required": ["memory_management"],
      "properties": {
        "memory_management": {
          "type": "object",
          "required": [
            "proactive_summarization",
            "context_monitoring",
            "session_transfer",
            "selective_export",
            "integration",
            "return_results",
            "hybrid_loading"
          ],
          "properties": {
            "proactive_summarization": {
              "type": "object",
              "required": ["triggers", "summary_format"],
              "properties": {
                "triggers": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 1
                },
                "summary_format": { "type": "string" }
              }
            },
            "context_monitoring": {
              "type": "object",
              "required": ["verdicts", "requirement"],
              "properties": {
                "verdicts": {
                  "type": "object",
                  "required": ["OPTIMAL", "WORKING", "WARNING", "STOP", "COMPRESSION"],
                  "patternProperties": {
                    "^[A-Z_]+$": {
                      "type": "object",
                      "required": ["condition", "description", "label"],
                      "properties": {
                        "condition": { "type": "string" },
                        "description": { "type": "string" },
                        "label": { "type": "string" },
                        "recommendation": { "type": "string" }
                      }
                    }
                  }
                },
                "requirement": { "type": "string" }
              }
            }
            // ... Аналогично детализировать остальные разделы protocol
          }
        }
      }
    },
    "commands": {
      "type": "object",
      "required": ["format", "tasks", "analysis", "system", "control"],
      "properties": {
        "format": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "analysis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "system": {
          "type": "array",
          "items": { "type": "string" }
        },
        "control": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "principles": {
      "type": "object",
      "required": ["proactivity", "structure", "honesty", "efficiency"],
      "properties": {
        "proactivity": { "type": "string" },
        "structure": { "type": "string" },
        "honesty": { "type": "string" },
        "efficiency": { "type": "string" }
      }
    },
    "confirmation": { "type": "string" }
  },
  "additionalProperties": false
}